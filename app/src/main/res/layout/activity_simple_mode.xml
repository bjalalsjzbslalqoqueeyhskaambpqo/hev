<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg">
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_atmosphere" />
    <ScrollView
        android:id="@+id/mainScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls"
        android:scrollbarStyle="outsideOverlay"
        android:scrollbars="none">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="28dp"
            android:gravity="center_horizontal">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginTop="16dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:id="@+id/imgLogo"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/strike_logo"
                        android:importantForAccessibility="no" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/app_brand"
                            android:textColor="@color/color_text_primary"
                            android:letterSpacing="0.20"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LOW LATENCY VPN"
                            android:textColor="@color/color_text_disabled"
                            android:letterSpacing="0.18"
                            android:textSize="9sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/panelConnection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/hud_status_badge"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="8dp">
                    <FrameLayout
                        android:layout_width="14dp"
                        android:layout_height="14dp">
                        <View
                            android:id="@+id/viewStatusHalo"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:alpha="0.20"
                            android:background="@drawable/shape_status_dot" />
                        <View
                            android:id="@+id/viewStatusHaloMid"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_gravity="center"
                            android:alpha="0.35"
                            android:background="@drawable/shape_status_dot" />
                        <View
                            android:id="@+id/viewStatusDot"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:layout_gravity="center"
                            android:background="@drawable/shape_status_dot" />
                    </FrameLayout>
                    <TextView
                        android:id="@+id/txtStatusBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:letterSpacing="0.16"
                        android:text="DESCONECTADO"
                        android:textColor="@color/color_disconnected"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <TextView
                    android:id="@+id/txtStatusDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_status_info_card"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.2"
                    android:visibility="gone" />
                <LinearLayout
                    android:id="@+id/panelConnLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/txtConnLogLatest"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/color_text_secondary"
                            android:textSize="11sp" />
                        <Button
                            android:id="@+id/btnConnLogToggle"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:background="@drawable/strike_btn_secondary"
                            android:minHeight="0dp"
                            android:text="Ver más"
                            android:textAllCaps="false"
                            android:textSize="11sp" />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/layoutConnLogExpanded"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="vertical"
                        android:visibility="gone">
                        <ScrollView
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:background="@drawable/strike_chip_left"
                            android:fillViewport="true">
                            <TextView
                                android:id="@+id/txtConnLogFull"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="8dp"
                                android:textColor="@color/color_text_secondary"
                                android:textIsSelectable="true"
                                android:textSize="10sp"
                                android:typeface="monospace" />
                        </ScrollView>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:orientation="horizontal">
                            <Button
                                android:id="@+id/btnConnLogCopy"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:background="@drawable/strike_btn_secondary"
                                android:minHeight="0dp"
                                android:text="Copiar"
                                android:textAllCaps="false"
                                android:textSize="11sp" />
                            <Button
                                android:id="@+id/btnConnLogClear"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/strike_btn_secondary"
                                android:minHeight="0dp"
                                android:text="Limpiar"
                                android:textAllCaps="false"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/layoutDataStrip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/hud_panel_metrics"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:paddingVertical="14dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <com.blacktunnel.PingPulseView
                        android:id="@+id/pingPulseView"
                        android:layout_width="32dp"
                        android:layout_height="22dp" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        android:layout_marginTop="4dp">
                        <TextView
                            android:id="@+id/txtPingValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="--"
                            android:textColor="@color/color_text_disabled"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:includeFontPadding="false" />
                        <TextView
                            android:id="@+id/txtPingUnit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="2dp"
                            android:paddingBottom="2dp"
                            android:text="ms"
                            android:textColor="@color/color_text_disabled"
                            android:textSize="8sp"
                            android:includeFontPadding="false" />
                    </LinearLayout>
                </LinearLayout>
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#18FFFFFF" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_calendar"
                        android:importantForAccessibility="no"
                        android:alpha="0.7" />
                    <TextView
                        android:id="@+id/txtDays"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="--"
                        android:textColor="@color/color_connected"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:includeFontPadding="false" />
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:id="@+id/txtHevRate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:textColor="@color/color_text_secondary"
                android:textSize="11sp"
                android:text="↑ --  ↓ --"
                android:visibility="gone" />
            <com.blacktunnel.ThroughputGraphView
                android:id="@+id/throughputGraphView"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="4dp"
                android:visibility="gone" />
            <TextView
                android:id="@+id/txtUserNameWide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/strike_chip_left"
                android:ellipsize="end"
                android:maxLines="2"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="Usuario: --"
                android:textColor="@color/color_text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/hud_panel_data"
                android:orientation="vertical"
                android:paddingHorizontal="18dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">
                <LinearLayout
                    android:id="@+id/panelGamingMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/gaming_mode_title"
                                android:textColor="@color/color_text_primary"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.06"
                                android:maxLines="1"
                                android:ellipsize="end" />
                            <TextView
                                android:id="@+id/txtGamingBadge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:letterSpacing="0.10"
                                android:text="@string/gaming_mode_off_compact"
                                android:textColor="@color/color_text_disabled"
                                android:textSize="10sp" />
                        </LinearLayout>
                        <Switch
                            android:id="@+id/switchGamingMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:showText="false"
                            android:thumbTint="@color/switch_thumb_gaming"
                            android:trackTint="@color/switch_track_gaming" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/txtGamingDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/gaming_mode_desc"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="11sp"
                        android:lineSpacingMultiplier="1.2"
                        android:maxLines="2"
                        android:visibility="gone" />
                    <LinearLayout
                        android:id="@+id/layoutGamingControls"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical"
                        android:visibility="gone">
                        <Button
                            android:id="@+id/btnSelectGamingApps"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/strike_btn_secondary"
                            android:stateListAnimator="@animator/btn_press"
                            android:text="@string/gaming_select_apps"
                            android:textAllCaps="false"
                            android:textColor="@color/color_gaming"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:hapticFeedbackEnabled="true" />
                        <TextView
                            android:id="@+id/txtGamingSelectedCount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/color_text_secondary"
                            android:textSize="11sp"
                            android:maxLines="2"
                            android:ellipsize="end" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <FrameLayout
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginTop="20dp"
                android:layout_gravity="center_horizontal">
                <View
                    android:id="@+id/btnRingOuter"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="center"
                    android:background="@drawable/hud_btn_ring_outer"
                    android:alpha="0.5" />
                <View
                    android:id="@+id/btnRingMid"
                    android:layout_width="136dp"
                    android:layout_height="136dp"
                    android:layout_gravity="center"
                    android:background="@drawable/hud_btn_ring_mid" />
                <View
                    android:id="@+id/btnTopDot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/shape_status_dot" />
                <Button
                    android:id="@+id/btnConnect"
                    android:layout_width="124dp"
                    android:layout_height="124dp"
                    android:layout_gravity="center"
                    android:background="@drawable/hud_btn_connect"
                    android:stateListAnimator="@animator/btn_press"
                    android:letterSpacing="0.02"
                    android:text="@string/connect"
                    android:textAllCaps="true"
                    android:textColor="@color/color_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:elevation="8dp"
                    android:hapticFeedbackEnabled="true" />
            </FrameLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/hud_panel_id"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp"
                android:paddingVertical="4dp">
                <TextView
                    android:id="@+id/txtDeviceId"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="7"
                    android:background="@drawable/strike_chip_left"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:maxLines="2"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp"
                    android:text="@string/device_id_default"
                    android:textColor="@color/color_text_primary"
                    android:textIsSelectable="true"
                    android:fontFamily="monospace"
                    android:textSize="10sp"
                    android:lineSpacingMultiplier="1.2" />
                <Button
                    android:id="@+id/btnCopyLogs"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="6dp"
                    android:layout_weight="3"
                    android:background="@drawable/strike_btn_secondary"
                    android:minHeight="0dp"
                    android:text="@string/copy"
                    android:textAllCaps="false"
                    android:textColor="@color/color_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:hapticFeedbackEnabled="true" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <LinearLayout
        android:id="@+id/panelFirstRun"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E610121B"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Primer acceso"
            android:textColor="@color/color_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Comparte este ID con el administrador para habilitar tu acceso."
            android:textColor="@color/color_text_secondary"
            android:textSize="13sp" />
        <TextView
            android:id="@+id/txtFirstRunId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/strike_chip_left"
            android:gravity="center"
            android:padding="12dp"
            android:textColor="@color/color_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
        <Button
            android:id="@+id/btnFirstRunCopy"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/strike_btn_secondary"
            android:text="Copiar ID"
            android:textAllCaps="false"
            android:textColor="@color/color_text_primary" />
        <Button
            android:id="@+id/btnFirstRunOk"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/hud_btn_connect"
            android:text="OK"
            android:textAllCaps="false"
            android:textColor="@color/color_text_primary"
            android:textStyle="bold" />
    </LinearLayout>
    <FrameLayout
        android:id="@+id/disconnectOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#D9111622"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="24dp"
            android:background="@drawable/bg_disconnect_overlay_panel"
            android:orientation="vertical"
            android:padding="24dp">
            <TextView
                android:id="@+id/txtOverlayBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/hud_status_badge"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="ALERTA DE ACCESO"
                android:textColor="@color/color_disconnected"
                android:textSize="11sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/txtOverlayTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:textColor="@color/color_disconnected"
                android:textSize="28sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/txtOverlayMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:textColor="@color/color_text_primary"
                android:textSize="17sp" />
            <Button
                android:id="@+id/btnOverlayClose"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/strike_btn_secondary"
                android:text="@string/overlay_close"
                android:textAllCaps="false" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
