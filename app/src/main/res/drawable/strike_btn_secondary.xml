<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <corners android:radius="8dp" />
            <solid android:color="#2C3B54" />
            <stroke
                android:width="1dp"
                android:color="#6D84A6" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="8dp" />
            <solid android:color="#1D2A3F" />
            <stroke
                android:width="1dp"
                android:color="#556C8B" />
        </shape>
    </item>
</selector>
