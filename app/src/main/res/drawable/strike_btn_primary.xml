<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <shape>
            <corners android:radius="14dp" />
            <gradient
                android:angle="270"
                android:startColor="#2A2A2A"
                android:endColor="#3A3A3A" />
            <stroke
                android:width="1dp"
                android:color="#FFFFFF10" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="14dp" />
            <gradient
                android:angle="270"
                android:startColor="#1F6FEB"
                android:endColor="#3AA0FF" />
            <stroke
                android:width="1dp"
                android:color="#FFFFFF10" />
        </shape>
    </item>
</selector>
