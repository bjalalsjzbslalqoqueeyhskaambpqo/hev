<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <layer-list>
            <item>
                <shape>
                    <solid android:color="#44FFB020" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
            <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
                <shape>
                    <gradient
                        android:angle="135"
                        android:startColor="#FFC34D"
                        android:endColor="#FFB020" />
                    <corners android:radius="13dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_pressed="true" android:state_activated="true">
        <layer-list>
            <item>
                <shape>
                    <solid android:color="#55FF4D4D" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
            <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
                <shape>
                    <gradient
                        android:angle="135"
                        android:startColor="#E63C3C"
                        android:endColor="#CC0000" />
                    <corners android:radius="13dp" />
                    <stroke
                        android:width="1dp"
                        android:color="#FF6B6B" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_activated="true">
        <layer-list>
            <item>
                <shape>
                    <solid android:color="#66FF4D4D" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
            <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
                <shape>
                    <gradient
                        android:angle="135"
                        android:startColor="#FF4D4D"
                        android:endColor="#FF0000" />
                    <corners android:radius="13dp" />
                    <stroke
                        android:width="1dp"
                        android:color="#FF6B6B" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_pressed="true">
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#CC00E0FF"
                android:endColor="#CC00BBD9" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <item>
        <layer-list>
            <item>
                <shape>
                    <solid android:color="#5500E0FF" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
            <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
                <shape>
                    <gradient
                        android:angle="135"
                        android:startColor="#00E0FF"
                        android:endColor="#00BBD9" />
                    <corners android:radius="13dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
